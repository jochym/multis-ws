#!/bin/bash
# postBuild script for repo2docker/mybinder
# Runs once after the environment is built

set -e

echo "Setting up workshop environment..."

# Install kernel
python -m ipykernel install --user --name=python3

# Verify abinit (from apt)
echo "Checking abinit..."
abinit --version || true

# Verify pseudopotentials from abinit-data
if [ -d "/usr/share/abinit/data/psps" ]; then
    echo "Pseudopotentials found in /usr/share/abinit/data/psps"
    ls /usr/share/abinit/data/psps/ | head -10
fi

# Verify data files
if [ -d "data" ]; then
    echo "Data files found in data/"
    ls data/
fi

echo "postBuild completed successfully!"